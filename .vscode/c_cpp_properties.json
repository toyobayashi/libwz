{
  "env": {
    "includePath": [
      "${default}",
      "${workspaceFolder}/include",
      "${workspaceFolder}/node_modules/node-addon-api",
      "${workspaceFolder}/build/_deps/*-src",
      "${workspaceFolder}/build/_deps/*-build",
      "${workspaceFolder}/build/_deps/*-src/**/include"
    ],
    // "defines": ["NAPI_DISABLE_CPP_EXCEPTIONS", "NODE_ADDON_API_ENABLE_MAYBE", "V8_ENABLE_DIRECT_LOCAL"],
    "gccPath": "/usr/bin/gcc",
    "clangPath": "/usr/bin/clang"
  },
  "configurations": [
    {
      "name": "Win32",
      "defines": ["_DEBUG", "UNICODE", "_UNICODE", "_CRT_SECURE_NO_WARNINGS"],
      "compilerPath": "C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\VC\\Tools\\MSVC\\14.44.35207\\bin\\Hostx64\\x64\\cl.exe",
      "windowsSdkVersion": "10.0.26100.0",
      "intelliSenseMode": "windows-msvc-x64",
      "cStandard": "c17",
      "cppStandard": "c++17",
      "includePath": [
        "${includePath}",
        "C:\\Program Files\\Amazon Corretto\\jdk21.0.11_10\\include",
        "C:\\Program Files\\Amazon Corretto\\jdk21.0.11_10\\include\\win32",
        "${env:USERPROFILE}/AppData/Local/node-gyp/Cache/24.12.0/include/node"
      ],
      "browse": {
        "path": ["${workspaceFolder}"]
      }
    },
    {
      "name": "Linux",
      "defines": ["${defines}"],
      "compilerPath": "${gccPath}",
      "cStandard": "c99",
      "cppStandard": "c++11",
      "intelliSenseMode": "gcc-x64",
      "browse": {
        "path": [
          "${workspaceFolder}"
        ],
        "limitSymbolsToIncludedHeaders": true,
        "databaseFilename": ""
      },
      "includePath": ["${includePath}"]
    },
    {
      "name": "macOS",
      "includePath": [
        "${includePath}",
        "${env:HOME}/Library/Java/JavaVirtualMachines/jbr-21.0.6/Contents/Home/include",
        "${env:HOME}/Library/Java/JavaVirtualMachines/jbr-21.0.6/Contents/Home/include/darwin"
      ],
      "defines": ["${defines}"],
      "macFrameworkPath": ["/System/Library/Frameworks", "/Library/Frameworks"],
      "compilerPath": "${clangPath}",
      "cStandard": "c17",
      "cppStandard": "c++17",
      "intelliSenseMode": "${default}"
    },
    {
      "name": "Emscripten",
      "defines": ["${defines}", "__wasm__", "__EMSCRIPTEN_PTHREADS__", "NAPI_VERSION=2147483647"],
      "compilerPath": "${env:EMSDK}/upstream/emscripten/emcc",
      "intelliSenseMode": "linux-clang-x86",
      "cStandard": "c11",
      "cppStandard": "c++17",
      "includePath": ["${includePath}"]
    },
    {
      "name": "Win32 Emscripten",
      "defines": ["${defines}", "__wasm__", "__EMSCRIPTEN_PTHREADS__", "NAPI_VERSION=2147483647"],
      "compilerPath": "${env:EMSDK}\\upstream\\emscripten\\emcc.bat",
      "intelliSenseMode": "linux-clang-x86",
      "cStandard": "c11",
      "cppStandard": "c++17",
      "includePath": ["${includePath}"]
    },
    {
      "name": "WASI",
      "defines": ["${defines}"],
      "compilerPath": "${env:WASI_SDK_PATH}/bin/clang",
      "intelliSenseMode": "clang-x86",
      "cStandard": "c11",
      "cppStandard": "c++17",
      "includePath": ["${includePath}"]
    },
    {
      "name": "WASI-THREADS",
      "defines": ["${defines}", "_REENTRANT"],
      "compilerPath": "${env:WASI_SDK_PATH}/bin/clang",
      "intelliSenseMode": "clang-x86",
      "cStandard": "c11",
      "cppStandard": "c++17",
      "includePath": ["${includePath}"],
      "compilerArgs": ["--target=wasm32-wasip1-threads"]
    },
    {
      "name": "WASM32",
      "defines": ["${defines}", "PAGESIZE=65536"],
      "compilerPath": "${env:WASI_SDK_PATH}/bin/clang",
      "intelliSenseMode": "clang-x86",
      "cStandard": "c11",
      "cppStandard": "c++17",
      "includePath": ["${includePath}"],
      "compilerArgs": ["--target=wasm32"]
    }
  ],
  "version": 4
}
