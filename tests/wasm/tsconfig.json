{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "es2022", "esnext.disposable"],
    "module": "es2022",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "target": "es2022",
    "types": []
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
